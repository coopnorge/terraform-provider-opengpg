{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
    ],
    "automerge": true,
    "automergeStrategy": "squash",
    "rebaseWhen": "conflicted",
    "postUpdateOptions": [
        "gomodTidy",
        "gomodUpdateImportPaths",
    ],
}
